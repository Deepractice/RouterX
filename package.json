{
  "name": "routerxjs",
  "version": "0.0.1",
  "description": "RouterX - Universal LLM API Router",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --env-file=.env.local packages/routerx/src/serve.ts",
    "build": "turbo build",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:bdd": "bun test bdd/run.test.ts",
    "test:e2e": "bun test bdd/e2e.test.ts",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "author": "Deepractice",
  "license": "MIT",
  "packageManager": "bun@1.3.5",
  "devDependencies": {
    "@agentxjs/core": "2.9.0-dev-20260317060607",
    "@agentxjs/mono-driver": "2.9.0-dev-20260317060607",
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@biomejs/biome": "^2.4.0",
    "@deepracticex/bdd": "^0.3.0",
    "@types/node": "^24.9.2",
    "agentxjs": "2.9.0-dev-20260317060607",
    "ai": "^6.0.116",
    "bun-types": "1.3.5",
    "tsup": "8.5.1",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.3.0"
  }
}
