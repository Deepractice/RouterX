{
  "name": "routerxjs",
  "version": "0.0.1",
  "description": "RouterX - Universal LLM API Router",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:bdd": "bun test bdd/",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "author": "Deepractice",
  "license": "MIT",
  "packageManager": "bun@1.3.5",
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@types/node": "^24.9.2",
    "bun-types": "1.3.5",
    "tsup": "8.5.1",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3",
    "@deepracticex/bdd": "^0.3.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.3.0"
  }
}
